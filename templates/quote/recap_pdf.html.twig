<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8"/>
		<title>Récapitulatif Devis #{{ quote.id }}</title>
		<style>
			* {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}

			body {
				font-family: "DejaVu Sans", Arial, sans-serif;
				font-size: 11px;
				color: #1e293b;
				background: #fff;
				padding: 0;
			}

			/* ── En-tête ────────────────────────────────────────────── */
			.header {
				background: linear-gradient(135deg, #0f62fe 0%, #0284c7 100%);
				color: #fff;
				padding: 28px 36px 22px;
			}
			.header-top {
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
				margin-bottom: 12px;
			}
			.brand {
				font-size: 22px;
				font-weight: 700;
				letter-spacing: 1px;
			}
			.brand span {
				opacity: 0.75;
				font-weight: 400;
			}
			.header-meta {
				text-align: right;
				font-size: 10px;
				opacity: 0.85;
			}
			.header-meta strong {
				display: block;
				font-size: 13px;
				opacity: 1;
			}

			.doc-title {
				font-size: 15px;
				font-weight: 600;
				border-top: 1px solid rgba(255, 255, 255, 0.3);
				padding-top: 12px;
				display: flex;
				align-items: center;
				gap: 8px;
			}

			/* ── Statut ─────────────────────────────────────────────── */
			.status-bar {
				padding: 10px 36px;
				font-size: 10.5px;
				display: flex;
				align-items: center;
				gap: 8px;
			}
			.status-bar.confirmed {
				background: #dbeafe;
				color: #1d4ed8;
			}
			.status-bar.submitted {
				background: #e0f2fe;
				color: #0369a1;
			}
			.status-bar.accepted {
				background: #dcfce7;
				color: #15803d;
			}
			.status-bar.rejected {
				background: #fee2e2;
				color: #b91c1c;
			}

			.status-dot {
				width: 8px;
				height: 8px;
				border-radius: 50%;
				display: inline-block;
			}
			.confirmed .status-dot {
				background: #1d4ed8;
			}
			.submitted .status-dot {
				background: #0369a1;
			}
			.accepted .status-dot {
				background: #15803d;
			}
			.rejected .status-dot {
				background: #b91c1c;
			}

			/* ── Corps ──────────────────────────────────────────────── */
			.body {
				padding: 20px 36px 30px;
			}

			.section {
				margin-bottom: 18px;
			}
			.section-title {
				font-size: 10px;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.8px;
				color: #0f62fe;
				border-bottom: 1.5px solid #bfdbfe;
				padding-bottom: 5px;
				margin-bottom: 10px;
			}

			table.info {
				width: 100%;
				border-collapse: collapse;
			}
			table.info td {
				padding: 5px 8px;
				vertical-align: middle;
				border-bottom: 1px solid #f1f5f9;
				line-height: 1.4;
			}
			table.info td:first-child {
				color: #64748b;
				font-weight: 600;
				width: 42%;
				font-size: 10px;
				text-transform: uppercase;
				letter-spacing: 0.4px;
			}
			table.info td:last-child {
				font-weight: 500;
				color: #1e293b;
			}
			table.info tr:last-child td {
				border-bottom: none;
			}

			/* ── Offre choisie ──────────────────────────────────────── */
			.offer-box {
				background: #f0f9ff;
				border: 1.5px solid #0284c7;
				border-radius: 6px;
				padding: 14px 18px;
				margin-bottom: 18px;
			}
			.offer-box .offer-label {
				font-size: 9.5px;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.6px;
				color: #0369a1;
				margin-bottom: 6px;
			}
			.offer-box .offer-name {
				font-size: 16px;
				font-weight: 700;
				color: #0f62fe;
			}
			.offer-box .offer-price {
				font-size: 13px;
				font-weight: 600;
				color: #0369a1;
				margin-top: 2px;
			}

			/* ── Deux colonnes ──────────────────────────────────────── */
			.two-col {
				display: flex;
				gap: 20px;
			}
			.two-col .section {
				flex: 1;
			}

			/* ── Pied de page ───────────────────────────────────────── */
			.footer {
				border-top: 1px solid #e2e8f0;
				padding: 12px 36px;
				font-size: 9px;
				color: #94a3b8;
				display: flex;
				justify-content: space-between;
				align-items: center;
			}
			.footer strong {
				color: #64748b;
			}
		</style>
	</head>
	<body>

		{# ── En-tête ─────────────────────────────────────────────────── #}
		<div class="header">
			<div class="header-top">
				<div class="brand">Aksam
					<span>Assurance</span>
				</div>
				<div class="header-meta">
					<strong>Devis #{{ quote.id }}</strong>
					Émis le
					{{ generatedAt|date('d/m/Y à H:i') }}
				</div>
			</div>
			<div class="doc-title">&#x2022; Récapitulatif de votre demande de devis</div>
		</div>

		{# ── Bande de statut ─────────────────────────────────────────── #}
		<div class="status-bar {{ quote.status|lower }}">
			<span class="status-dot"></span>
			Statut du dossier :
			<strong>
				{% if quote.status == 'confirmed' %}Confirmé
					{% elseif quote.status == 'submitted' %}Soumis
					{% elseif quote.status == 'accepted' %}Accepté
					{% elseif quote.status == 'rejected' %}Rejeté
				{% else %}
					{{ quote.status|capitalize }}
				{% endif %}
			</strong>
		</div>

		<div
			class="body">

			{# ── Offre choisie (si disponible) ───────────────────────── #}
			{% if quote.selectedOffer is defined and quote.selectedOffer %}
				<div class="offer-box">
					<div class="offer-label">&#x2713; Offre sélectionnée</div>
					<div class="offer-name">{{ quote.selectedOffer|capitalize }}</div>
					{% if quote.customEstimation is defined and quote.customEstimation %}
						<div class="offer-price">Prime annuelle estimée :
							{{ quote.customEstimation|number_format(2, ',', ' ') }}
							MAD</div>
					{% endif %}
				</div>
			{% endif %}

			{# ── Infos personnelles + conducteur ─────────────────────── #}
			<div class="two-col">
				<div class="section">
					<div class="section-title">Informations personnelles</div>
					<table class="info">
						<tr>
							<td>Nom</td>
							<td>{{ quote.lastName }}</td>
						</tr>
						<tr>
							<td>Prénom</td>
							<td>{{ quote.firstName }}</td>
						</tr>
						<tr>
							<td>Téléphone</td>
							<td>{{ quote.phoneNumber }}</td>
						</tr>
						<tr>
							<td>Ville</td>
							<td>{{ quote.city|capitalize }}</td>
						</tr>
						<tr>
							<td>Compagnie</td>
							<td>{{ quote.company|capitalize }}</td>
						</tr>
					</table>
				</div>

				<div class="section">
					<div class="section-title">Conducteur</div>
					<table class="info">
						<tr>
							<td>Date de naissance</td>
							<td>{{ quote.birthDate|date('d/m/Y') }}</td>
						</tr>
						<tr>
							<td>Date du permis</td>
							<td>{{ quote.licenseDate|date('d/m/Y') }}</td>
						</tr>
						<tr>
							<td>Expérience</td>
							<td>
								{% set years = (("now"|date('U') - (quote.licenseDate|date('U'))) / 31557600)|round %}
								{{ years }}
								an(s)
							</td>
						</tr>
					</table>
				</div>
			</div>

			{# ── Type d'assurance ────────────────────────────────────── #}
			<div class="section">
				<div class="section-title">Type d'assurance</div>
				<table class="info">
					<tr>
						<td>Type</td>
						<td>
							{% if quote.insuranceType == 'auto' %}Assurance Auto
								{% else %}Assurance Moto
							{% endif %}
						</td>
					</tr>
					<tr>
						<td>Demande créée le</td>
						<td>{{ quote.createdAt|date('d/m/Y') }}</td>
					</tr>
				</table>
			</div>

			{# ── Véhicule ────────────────────────────────────────────── #}
			<div class="section">
				<div class="section-title">Informations du véhicule</div>
				<table class="info">
					<tr>
						<td>Marque</td>
						<td>{{ quote.vehicleBrand|capitalize }}</td>
					</tr>
					<tr>
						<td>Carburant</td>
						<td>{{ quote.fuelType|capitalize }}</td>
					</tr>
					<tr>
						<td>Mise en circulation</td>
						<td>{{ quote.firstRegistrationDate|date('d/m/Y') }}</td>
					</tr>
					<tr>
						<td>Nombre de places</td>
						<td>{{ quote.seatCount }}</td>
					</tr>
					<tr>
						<td>Valeur à neuf</td>
						<td>{{ quote.newValue|number_format(2, ',', ' ') }}
							MAD</td>
					</tr>
					<tr>
						<td>Valeur vénale</td>
						<td>{{ quote.marketValue|number_format(2, ',', ' ') }}
							MAD</td>
					</tr>
					<tr>
						<td>Immatriculation</td>
						<td>
							<strong>{{ quote.registrationNumber }}</strong>
						</td>
					</tr>
					{% if quote.insuranceType == 'auto' and quote.fiscalPower %}
						<tr>
							<td>Puissance fiscale</td>
							<td>{{ quote.fiscalPower }}
								CV</td>
						</tr>
					{% endif %}
					{% if quote.insuranceType == 'moto' and quote.engineCapacity %}
						<tr>
							<td>Cylindrée</td>
							<td>{{ quote.engineCapacity }}
								cc</td>
						</tr>
					{% endif %}
				</table>
			</div>

		</div>

		{# ── Pied de page ────────────────────────────────────────────── #}
		<div class="footer">
			<span>Document généré automatiquement —
				<strong>Aksam Assurance</strong>
			</span>
			<span>Ref. DEV-{{ quote.id }}-{{ generatedAt|date('Ymd') }}</span>
		</div>

	</body>
</html>
