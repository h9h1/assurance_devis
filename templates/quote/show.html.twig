{% extends 'base.html.twig' %}

{% block title %}Devis #{{ quote.id }}
	| Aksam Assurance
{% endblock %}

{% block body %}
	<!-- Success Header -->
	<div class="success-header">
		<div class="success-icon">
			<i class="fas fa-check-circle"></i>
		</div>
		<h1>Devis enregistré avec succès</h1>
		<p>Votre demande de devis #{{ quote.id }}
			a été bien reçue</p>
	</div>

	<!-- Summary Grid -->
	<div
		class="summary-grid">
		<!-- Personal Information -->
		<div class="summary-section">
			<div class="section-header">
				<i class="fas fa-user"></i>
				<h2>Informations personnelles</h2>
			</div>
			<div class="section-body">
				<div class="info-row">
					<span class="label">Nom</span>
					<span class="value">{{ quote.lastName }}</span>
				</div>
				<div class="info-row">
					<span class="label">Prénom</span>
					<span class="value">{{ quote.firstName }}</span>
				</div>
				<div class="info-row">
					<span class="label">Ville</span>
					<span class="value">{{ quote.city }}</span>
				</div>
				<div class="info-row">
					<span class="label">Téléphone</span>
					<span class="value">
						<a href="tel:{{ quote.phoneNumber }}">{{ quote.phoneNumber }}</a>
					</span>
				</div>
			</div>
		</div>

		<!-- Driver Information -->
		<div class="summary-section">
			<div class="section-header">
				<i class="fas fa-id-card"></i>
				<h2>Informations du conducteur</h2>
			</div>
			<div class="section-body">
				<div class="info-row">
					<span class="label">Date de naissance</span>
					<span class="value">{{ quote.birthDate|date('d/m/Y') }}</span>
				</div>
				<div class="info-row">
					<span class="label">Date du permis</span>
					<span class="value">{{ quote.licenseDate|date('d/m/Y') }}</span>
				</div>
				<div class="info-row">
					<span class="label">Expérience</span>
					<span class="value">
						{% set years = (("now"|date('U') - (quote.licenseDate|date('U'))) / 31557600) | round %}
						{{ years }}
						an(s)
					</span>
				</div>
			</div>
		</div>

		<!-- Insurance Information -->
		<div class="summary-section">
			<div class="section-header">
				<i class="fas fa-shield-alt"></i>
				<h2>Type d'assurance</h2>
			</div>
			<div class="section-body">
				<div class="info-row">
					<span class="label">Type</span>
					<span class="value badge-type">
						{% if quote.insuranceType == 'auto' %}
							<i class="fas fa-car"></i>
							Assurance Auto
						{% else %}
							<i class="fas fa-motorcycle"></i>
							Assurance Moto
						{% endif %}
					</span>
				</div>
				<div class="info-row">
					<span class="label">Statut</span>
					<span class="status-badge status-badge--{{ quote.status|lower }}">
						{{ quote.status }}
					</span>
				</div>
			</div>
		</div>

		<!-- Vehicle Information -->
		<div class="summary-section section-full">
			<div class="section-header">
				<i class="fas fa-car-alt"></i>
				<h2>Informations du véhicule</h2>
			</div>
			<div class="section-body">
				<div class="vehicle-grid">
					<div class="info-row">
						<span class="label">Marque</span>
						<span class="value">{{ quote.vehicleBrand }}</span>
					</div>
					<div class="info-row">
						<span class="label">Carburant</span>
						<span class="value">{{ quote.fuelType|capitalize }}</span>
					</div>
					<div class="info-row">
						<span class="label">Mise en circulation</span>
						<span class="value">{{ quote.firstRegistrationDate|date('d/m/Y') }}</span>
					</div>
					<div class="info-row">
						<span class="label">Nombre de places</span>
						<span class="value">{{ quote.seatCount }}</span>
					</div>
					<div class="info-row">
						<span class="label">Valeur à neuf</span>
						<span class="value">{{ quote.newValue }}
							MAD</span>
					</div>
					<div class="info-row">
						<span class="label">Valeur vénale</span>
						<span class="value">{{ quote.marketValue }}
							MAD</span>
					</div>
					<div class="info-row">
						<span class="label">Immatriculation</span>
						<span class="value font-mono">{{ quote.registrationNumber }}</span>
					</div>
					{% if quote.insuranceType == 'auto' %}
						<div class="info-row">
							<span class="label">Puissance fiscale</span>
							<span class="value">{{ quote.fiscalPower ?? '-' }}</span>
						</div>
					{% endif %}
					{% if quote.insuranceType == 'moto' %}
						<div class="info-row">
							<span class="label">Cylindrée</span>
							<span class="value">{{ quote.engineCapacity ?? '-' }}
								cc</span>
						</div>
					{% endif %}
				</div>
			</div>
		</div>
	</div>

	<!-- Actions -->
	<div class="actions-container">
		<a href="{{ path('quote_new') }}" class="btn btn-secondary">
			<i class="fas fa-plus-circle"></i>
			Créer un autre devis
		</a>
		<button type="button" class="btn btn-email" id="openEmailModal">
			<i class="fas fa-envelope"></i>
			Recevoir par email
		</button>
		<a href="{{ path('quote_offers', {uuid: quote.uuid, token: quote.accessToken}) }}" class="btn btn-primary">
			<i class="fas fa-arrow-right"></i>
			Voir les offres disponibles
		</a>
		 <a href="{{ path('quote_recap_pdf', {uuid: quote.uuid, token: quote.accessToken}) }}"
           class="btn btn-download"
           title="Télécharger le récapitulatif PDF">
            <i class="fas fa-file-pdf"></i>
            Télécharger le récapitulatif
        </a>
	</div>

	<style>
		/* Success Header */
		.success-header {
			text-align: center;
			padding: 48px 24px;
			margin-bottom: 48px;
			background: linear-gradient(135deg, var(--success-light), rgba(18, 128, 92, 0.05));
			border-radius: var(--radius-lg);
			border: 2px solid var(--success);
		}

		.success-icon {
			font-size: 4rem;
			color: var(--success);
			margin-bottom: 16px;
			animation: bounceIn 0.6s ease;
		}

		@keyframes bounceIn {
			0% {
				transform: scale(0);
				opacity: 0;
			}
			50% {
				transform: scale(1.05);
			}
			100% {
				transform: scale(1);
				opacity: 1;
			}
		}

		.success-header h1 {
			font-size: 2rem;
			margin: 0 0 8px;
			color: var(--success);
		}

		.success-header p {
			margin: 0;
			color: var(--text-secondary);
			font-size: 1.1rem;
		}

		/* Summary Grid */
		.summary-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
			gap: 24px;
			margin-bottom: 48px;
		}

		.section-full {
			grid-column: 1 / -1;
		}

		.summary-section {
			background: var(--surface);
			border-radius: var(--radius);
			border: 1px solid var(--border);
			overflow: hidden;
			transition: var(--transition);
			box-shadow: var(--shadow-sm);
		}

		.summary-section:hover {
			transform: translateY(-2px);
			box-shadow: var(--shadow);
			border-color: var(--primary);
		}

		.section-header {
			display: flex;
			align-items: center;
			gap: 12px;
			padding: 20px 24px;
			background: linear-gradient(135deg, var(--primary-light), var(--info-light));
			border-bottom: 1px solid var(--border);
		}

		.section-header i {
			font-size: 1.5rem;
			color: var(--primary);
		}

		.section-header h2 {
			margin: 0;
			font-size: 1.1rem;
			color: var(--text);
		}

		.section-body {
			padding: 24px;
		}

		.info-row {
			display: flex;
			justify-content: space-between;
			align-items: center;
			padding: 12px 0;
			border-bottom: 1px solid var(--surface-muted);
		}

		.info-row:last-child {
			border-bottom: none;
			padding-bottom: 0;
		}

		.info-row:first-child {
			padding-top: 0;
		}

		.label {
			font-weight: 600;
			color: var(--text-secondary);
			font-size: 0.9rem;
			text-transform: uppercase;
			letter-spacing: 0.5px;
		}

		.value {
			font-weight: 500;
			color: var(--text);
			text-align: right;
		}

		.value a {
			color: var(--primary);
			text-decoration: none;
			transition: var(--transition);
		}

		.value a:hover {
			color: var(--primary-dark);
		}

		.font-mono {
			font-family: 'Courier New', monospace;
			letter-spacing: 1px;
			font-weight: 700;
		}

		.badge-type {
			display: inline-flex;
			align-items: center;
			gap: 6px;
			background: var(--primary-light);
			color: var(--primary);
			padding: 6px 12px;
			border-radius: 6px;
			font-weight: 600;
			font-size: 0.85rem;
		}

		.status-badge {
			display: inline-block;
			padding: 6px 12px;
			border-radius: 6px;
			font-size: 0.85rem;
			font-weight: 600;
			text-transform: capitalize;
		}

		.status-badge--confirmed {
			background: var(--primary-light);
			color: var(--primary);
		}

		.status-badge--submitted {
			background: var(--info-light);
			color: var(--info);
		}

		.status-badge--accepted {
			background: var(--success-light);
			color: var(--success);
		}

		.status-badge--rejected {
			background: var(--danger-light);
			color: var(--danger);
		}

		/* Vehicle Grid */
		.vehicle-grid {
			display: grid;
			grid-template-columns: repeat(2, 1fr);
			gap: 16px;
		}

		.vehicle-grid .info-row {
			border: none;
			padding: 12px;
			background: var(--surface-muted);
			border-radius: 8px;
			flex-direction: column;
			align-items: flex-start;
			gap: 4px;
		}

		/* Actions */
		.actions-container {
			display: flex;
			gap: 16px;
			justify-content: center;
			flex-wrap: wrap;
		}

		.btn {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			gap: 8px;
			padding: 12px 24px;
			border: none;
			border-radius: var(--radius);
			font-weight: 600;
			cursor: pointer;
			transition: var(--transition);
			font-size: 1rem;
			text-decoration: none;
		}
			.btn-download {
            background: linear-gradient(135deg, #dc2626, #b91c1c);
            color: white;
        }

        .btn-download:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 16px rgba(220, 38, 38, 0.3);
        }

		.btn-primary {
			background: linear-gradient(135deg, var(--primary), var(--info));
			color: white;
		}

		.btn-primary:hover {
			transform: translateY(-2px);
			box-shadow: 0 8px 16px rgba(15, 98, 254, 0.3);
		}

		.btn-secondary {
			background: var(--surface-muted);
			color: var(--text);
			border: 1px solid var(--border);
		}

		.btn-secondary:hover {
			background: var(--border);
			border-color: var(--text-secondary);
			transform: translateY(-2px);
		}

		/* Responsive */
		@media(max-width: 768px) {
			.summary-grid {
				grid-template-columns: 1fr;
				gap: 16px;
			}

			.success-header {
				padding: 32px 16px;
			}

			.success-header h1 {
				font-size: 1.5rem;
			}

			.success-icon {
				font-size: 3rem;
			}

			.info-row {
				flex-direction: column;
				align-items: flex-start;
				gap: 6px;
			}

			.value {
				text-align: left;
			}

			.vehicle-grid {
				grid-template-columns: 1fr;
			}

			.actions-container {
				flex-direction: column;
			}

			.btn {
				width: 100%;
			}
		}
	</style>

{# ── Modal Email ────────────────────────────────────────────────────────── #}
<div id="emailModal" class="modal-overlay" style="display:none;">
	<div class="modal-card">
		<button class="modal-close" id="closeEmailModal"><i class="fas fa-times"></i></button>
		<div class="modal-icon"><i class="fas fa-envelope"></i></div>
		<h3 class="modal-title">Recevoir le récapitulatif</h3>
		<p class="modal-desc">Entrez votre email pour recevoir le récapitulatif de votre devis <strong>#{{ quote.id }}</strong>.</p>
		<form method="POST" action="{{ path('quote_send_email', {uuid: quote.uuid, token: quote.accessToken}) }}">
			<div class="modal-field">
				<label for="modalEmail">Adresse email</label>
				<div class="modal-input-wrap">
					<i class="fas fa-at modal-input-icon"></i>
					{% if quote.email %}
							<input type="email" id="modalEmail" name="email"
								value="{{ quote.email }}"
								required
								placeholder="votre@email.com">
							<span class="field-hint" style="font-size:.8rem;color:#12805c;margin-top:6px;display:flex;align-items:center;gap:6px;">
								<i class="fas fa-check-circle"></i>
								Email renseigné lors de votre demande
							</span>
						{% else %}
							<input type="email" id="modalEmail" name="email"
								value=""
								required
								placeholder="votre@email.com">
						{% endif %}
				</div>
			</div>
			<div class="modal-actions">
				<button type="submit" class="btn btn-primary"><i class="fas fa-paper-plane"></i> Envoyer</button>
				<button type="button" class="btn btn-secondary" id="cancelEmailModal">Annuler</button>
			</div>
		</form>
	</div>
</div>

<style>
.btn-email{background:linear-gradient(135deg,#12805c,#0d6e4f);color:white;border:none;border-radius:10px;padding:12px 20px;font-size:.9rem;font-weight:600;cursor:pointer;display:inline-flex;align-items:center;gap:8px;transition:all .3s ease}
.btn-email:hover{transform:translateY(-2px);box-shadow:0 8px 20px rgba(18,128,92,.3)}
.modal-overlay{position:fixed;inset:0;background:rgba(18,32,51,.55);z-index:9999;align-items:center;justify-content:center;padding:24px;backdrop-filter:blur(4px)}
.modal-card{background:#fff;border-radius:18px;box-shadow:0 32px 64px rgba(15,48,87,.18);padding:40px;max-width:460px;width:100%;position:relative;animation:modalIn .25s ease}
@keyframes modalIn{from{opacity:0;transform:scale(.95) translateY(8px)}to{opacity:1;transform:scale(1) translateY(0)}}
.modal-close{position:absolute;top:16px;right:16px;background:#f4f7fb;border:1px solid #dbe4ee;border-radius:8px;width:32px;height:32px;display:flex;align-items:center;justify-content:center;cursor:pointer;color:#607086;font-size:.85rem;transition:all .2s}
.modal-close:hover{background:#dbe4ee;color:#122033}
.modal-icon{width:56px;height:56px;border-radius:14px;background:linear-gradient(135deg,#e3f2fd,#e0e7ff);color:#0f62fe;display:flex;align-items:center;justify-content:center;font-size:1.4rem;margin-bottom:20px}
.modal-title{font-size:1.3rem;font-weight:700;color:#122033;margin:0 0 8px}
.modal-desc{color:#607086;font-size:.9rem;line-height:1.6;margin:0 0 24px}
.modal-field{margin-bottom:20px}
.modal-field label{display:block;font-size:.875rem;font-weight:600;color:#122033;margin-bottom:8px}
.modal-input-wrap{position:relative}
.modal-input-icon{position:absolute;left:14px;top:50%;transform:translateY(-50%);color:#607086;pointer-events:none}
.modal-input-wrap input{width:100%;padding:13px 16px 13px 42px;border:2px solid #dbe4ee;border-radius:12px;font-size:1rem;color:#122033;background:#fff;outline:none;font-family:inherit;box-sizing:border-box;transition:border-color .2s,box-shadow .2s}
.modal-input-wrap input:focus{border-color:#0f62fe;box-shadow:0 0 0 4px #e3f2fd}
.modal-actions{display:flex;gap:12px}
.modal-actions .btn{flex:1;justify-content:center}
</style>

<script>
(function(){
    var modal     = document.getElementById('emailModal');
    var openBtn   = document.getElementById('openEmailModal');
    var closeBtn  = document.getElementById('closeEmailModal');
    var cancelBtn = document.getElementById('cancelEmailModal');
    var input     = document.getElementById('modalEmail');

    function open()  { modal.style.display='flex'; setTimeout(function(){ input.focus(); },100); }
    function close() { modal.style.display='none'; }

    if(openBtn)   openBtn.addEventListener('click', open);
    if(closeBtn)  closeBtn.addEventListener('click', close);
    if(cancelBtn) cancelBtn.addEventListener('click', close);
    modal.addEventListener('click', function(e){ if(e.target===modal) close(); });
    document.addEventListener('keydown', function(e){ if(e.key==='Escape' && modal.style.display==='flex') close(); });
})();
</script>

{% endblock %}