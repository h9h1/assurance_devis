<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Accès refusé — Aksam Assurance</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        {% include 'bundles/TwigBundle/Exception/_error_styles.html.twig' %}
        .error-code { color: #f59e0b; }
        .error-icon { background: linear-gradient(135deg, #fffbeb, #fef3c7); color: #f59e0b; }
        .orb-1      { background: #f59e0b; top: -180px; right: -100px; }
        .orb-2      { background: #d97706; bottom: -120px; left: -80px; }
    </style>
</head>
<body>
    {% include 'bundles/TwigBundle/Exception/_error_layout.html.twig' with {
        code:     '403',
        icon:     'fa-lock',
        title:    'Accès refusé',
        message:  'Vous n\'avez pas les permissions nécessaires pour accéder à cette page.',
        hint:     'Si vous êtes admin, connectez-vous via l\'espace dédié.',
        actions: [
            { url: '/admin/login', icon: 'fa-sign-in-alt', label: 'Se connecter',  primary: true  },
            { url: '/',            icon: 'fa-home',         label: 'Retour accueil', primary: false },
        ]
    } %}
</body>
</html>
