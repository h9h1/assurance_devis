<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Page introuvable — Aksam Assurance</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        {% include 'bundles/TwigBundle/Exception/_error_styles.html.twig' %}
        .error-code   { color: #0f62fe; }
        .error-icon   { background: linear-gradient(135deg, #e3f2fd, #e0e7ff); color: #0f62fe; }
        .orb-1        { background: #0f62fe; top: -180px; right: -100px; }
        .orb-2        { background: #0043ce; bottom: -120px; left: -80px; }
    </style>
</head>
<body>
    {% include 'bundles/TwigBundle/Exception/_error_layout.html.twig' with {
        code:     '404',
        icon:     'fa-map-signs',
        title:    'Page introuvable',
        message:  'La page que vous cherchez n\'existe pas ou a été déplacée.',
        hint:     'Vérifiez l\'URL ou retournez à l\'accueil pour continuer.',
        actions: [
            { url: '/',            icon: 'fa-home',          label: 'Accueil',       primary: true },
            { url: '/devis/nouveau', icon: 'fa-file-contract', label: 'Nouveau devis', primary: false },
        ]
    } %}
</body>
</html>
