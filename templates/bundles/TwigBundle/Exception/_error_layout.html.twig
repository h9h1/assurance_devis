<div class="error-page">

    {# Background orbs #}
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>

    {# Floating decorations #}
    <div class="deco deco-1"><i class="fas fa-shield-alt"></i> Aksam Assurance</div>
    <div class="deco deco-2"><i class="fas fa-headset"></i> Support disponible</div>
    <div class="deco deco-3"><i class="fas fa-lock"></i> Connexion sécurisée</div>

    {# Brand header #}
    <div class="error-header">
        <a href="/" class="brand-link">
            <div class="brand-icon"><i class="fas fa-shield-alt"></i></div>
            Aksam Assurance
        </a>
    </div>

    {# Main card #}
    <div class="error-card">

        <div class="error-icon">
            <i class="fas {{ icon }}"></i>
        </div>

        <div class="error-code">{{ code }}</div>
        <h1 class="error-title">{{ title }}</h1>
        <p class="error-message">{{ message }}</p>
        <p class="error-hint">{{ hint }}</p>

        <div class="error-divider"></div>

        <div class="error-actions">
            {% for action in actions %}
                <a href="{{ action.url }}" class="btn {{ action.primary ? 'btn-primary' : 'btn-secondary' }}">
                    <i class="fas {{ action.icon }}"></i>
                    {{ action.label }}
                </a>
            {% endfor %}
        </div>

    </div>

    {# Footer #}
    <div class="error-footer">
        &copy; {{ "now"|date("Y") }} Aksam Assurance —
        <a href="/">Retour à l'accueil</a>
    </div>

</div>
