:root {
    --primary:        #0f62fe;
    --primary-dark:   #0a4bcc;
    --primary-light:  #e3f2fd;
    --success:        #12805c;
    --danger:         #c0392b;
    --warning:        #f59e0b;
    --info:           #0043ce;
    --bg:             #f4f7fb;
    --surface:        #ffffff;
    --surface-muted:  #f8fafc;
    --text:           #122033;
    --text-secondary: #607086;
    --border:         #dbe4ee;
    --shadow:         0 20px 45px rgba(15,48,87,.08);
    --shadow-sm:      0 2px 8px rgba(15,48,87,.06);
    --radius:         12px;
    --radius-lg:      18px;
    --transition:     all .3s cubic-bezier(.4,0,.2,1);
}

*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }

html, body {
    height: 100%;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background: linear-gradient(180deg, #eef4fb 0%, var(--bg) 100%);
    color: var(--text);
    line-height: 1.6;
}

/* Page */
.error-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px 24px;
    position: relative;
    overflow: hidden;
}

/* Background orbs */
.orb {
    position: fixed;
    border-radius: 50%;
    filter: blur(90px);
    opacity: .07;
    pointer-events: none;
    z-index: 0;
}

.orb-1 { width: 600px; height: 600px; }
.orb-2 { width: 400px; height: 400px; }

/* Header */
.error-header {
    position: relative;
    z-index: 1;
    text-align: center;
    margin-bottom: 40px;
}

.brand-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--text);
    font-size: 1.2rem;
    font-weight: 700;
    transition: var(--transition);
}

.brand-link:hover { opacity: .8; }

.brand-icon {
    width: 40px; height: 40px;
    border-radius: 10px;
    background: linear-gradient(135deg, var(--primary), var(--info));
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 1rem;
}

/* Card */
.error-card {
    position: relative;
    z-index: 1;
    background: var(--surface);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    padding: 56px 48px;
    max-width: 560px;
    width: 100%;
    text-align: center;
}

/* Error icon */
.error-icon {
    width: 96px; height: 96px;
    border-radius: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.4rem;
    margin: 0 auto 28px;
    border: 1px solid rgba(0,0,0,.06);
}

/* Error code */
.error-code {
    font-size: 5rem;
    font-weight: 900;
    line-height: 1;
    margin-bottom: 8px;
    letter-spacing: -4px;
}

/* Title */
.error-title {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 12px;
}

/* Message */
.error-message {
    font-size: 1rem;
    color: var(--text-secondary);
    margin-bottom: 8px;
    line-height: 1.6;
}

/* Hint */
.error-hint {
    font-size: .875rem;
    color: var(--text-secondary);
    opacity: .75;
    margin-bottom: 36px;
    font-style: italic;
}

/* Divider */
.error-divider {
    height: 1px;
    background: var(--border);
    margin-bottom: 32px;
}

/* Actions */
.error-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
}

.btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: var(--radius);
    font-size: .95rem;
    font-weight: 600;
    cursor: pointer;
    transition: var(--transition);
    text-decoration: none;
    border: none;
}

.btn-primary {
    background: linear-gradient(135deg, var(--primary), var(--info));
    color: white;
    box-shadow: 0 4px 14px rgba(15,98,254,.25);
}

.btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 24px rgba(15,98,254,.35);
    color: white;
    text-decoration: none;
}

.btn-secondary {
    background: var(--surface-muted);
    color: var(--text);
    border: 1px solid var(--border);
}

.btn-secondary:hover {
    background: var(--border);
    transform: translateY(-2px);
    text-decoration: none;
    color: var(--text);
}

/* Footer */
.error-footer {
    position: relative;
    z-index: 1;
    margin-top: 32px;
    text-align: center;
    font-size: .82rem;
    color: var(--text-secondary);
}

.error-footer a {
    color: var(--primary);
    text-decoration: none;
}

.error-footer a:hover { text-decoration: underline; }

/* Floating decorations */
.deco {
    position: absolute;
    border-radius: var(--radius);
    background: var(--surface);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-sm);
    padding: 10px 16px;
    font-size: .82rem;
    font-weight: 600;
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    gap: 8px;
    z-index: 0;
    opacity: .7;
}

.deco i { color: var(--primary); }
.deco-1 { top: 15%; left: 8%; }
.deco-2 { bottom: 20%; right: 8%; }
.deco-3 { top: 60%; left: 5%; }

@media (max-width: 600px) {
    .error-card   { padding: 36px 24px; }
    .error-code   { font-size: 3.5rem; letter-spacing: -2px; }
    .error-icon   { width: 72px; height: 72px; font-size: 1.8rem; }
    .error-title  { font-size: 1.3rem; }
    .error-actions { flex-direction: column; }
    .btn { justify-content: center; }
    .deco { display: none; }
}
