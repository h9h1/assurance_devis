{% extends '@EasyAdmin/page/content.html.twig' %}

{% block page_title %}Tableau de Bord{% endblock %}

{% block main %}
<div class="admin-dashboard">
	<!-- Header -->
	<div class="dashboard-header">
		<div>
			<h1>Tableau de Bord</h1>
			<p class="text-muted">Bienvenue dans votre espace de gestion</p>
		</div>
	</div>

	<!-- Statistics Cards -->
	<div class="stats-grid">
		<div class="stat-card stat-card--primary">
			<div class="stat-card__icon">
				<i class="fas fa-file-contract"></i>
			</div>
			<div class="stat-card__content">
				<p class="stat-card__label">Total Devis</p>
				<h2 class="stat-card__value">{{ total }}</h2>
			</div>
		</div>

		<div class="stat-card stat-card--success">
			<div class="stat-card__icon">
				<i class="fas fa-check-circle"></i>
			</div>
			<div class="stat-card__content">
				<p class="stat-card__label">Acceptés</p>
				<h2 class="stat-card__value">{{ accepted }}</h2>
			</div>
		</div>

		<div class="stat-card stat-card--info">
			<div class="stat-card__icon">
				<i class="fas fa-paper-plane"></i>
			</div>
			<div class="stat-card__content">
				<p class="stat-card__label">Soumis</p>
				<h2 class="stat-card__value">{{ submitted }}</h2>
			</div>
		</div>

		<div class="stat-card stat-card--danger">
			<div class="stat-card__icon">
				<i class="fas fa-times-circle"></i>
			</div>
			<div class="stat-card__content">
				<p class="stat-card__label">Rejetés</p>
				<h2 class="stat-card__value">{{ rejected }}</h2>
			</div>
		</div>
	</div>

	<!-- Latest Quotes Table -->
	<div class="table-wrapper">
		<div class="table-header">
			<h2>Derniers Devis</h2>
			<a href="{{ quotesUrl }}" class="btn btn-primary btn-sm">
				<i class="fas fa-arrow-right"></i> Tous les devis
			</a>
		</div>

		<div class="table-container">
			{% if latestQuotes|length > 0 %}
				<table class="modern-table">
					<thead>
						<tr>
							<th>N°</th>
							<th>Client</th>
							<th>Compagnie</th>
							<th>Statut</th>
							<th>Estimation</th>
							<th>Date</th>
							<th class="text-center">Actions</th>
						</tr>
					</thead>
					<tbody>
						{% for quote in latestQuotes %}
							<tr class="table-row">
								<td class="td-id"><strong>#{{ quote.id }}</strong></td>
								<td class="td-client">
									<div class="client-info">
										<div class="client-avatar">{{ quote.firstName|slice(0,1)|upper }}{{ quote.lastName|slice(0,1)|upper }}</div>
										<div>
											<p class="client-name">{{ quote.firstName }} {{ quote.lastName }}</p>
											<p class="client-phone">{{ quote.phoneNumber }}</p>
										</div>
									</div>
								</td>
								<td>
									<span class="badge-company">
										{% if quote.companyEntity %}
											{{ quote.companyEntity.name }}
										{% elseif quote.company %}
											{{ quote.company.value }}
										{% else %}
											<span class="text-muted">-</span>
										{% endif %}
									</span>
								</td>
								<td>
									<span class="status-badge status-badge--{{ quote.status.value|lower }}">
										{{ quote.status.value|replace({'_': ' '}) }}
									</span>
								</td>
								<td class="td-price">
									{% if quote.customEstimation %}
										<strong class="price">{{ quote.customEstimation|number_format(2, ',', ' ') }}€</strong>
									{% else %}
										<span class="text-muted">En attente</span>
									{% endif %}
								</td>
								<td class="td-date">
									<time class="date-time">{{ quote.createdAt|date('d/m/Y H:i') }}</time>
								</td>
								<td class="text-center">
									<button class="btn-icon" title="Voir les détails">
										<i class="fas fa-eye"></i>
									</button>
								</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			{% else %}
				<div class="empty-state">
					<i class="fas fa-inbox"></i>
					<p>Aucun devis trouvé</p>
				</div>
			{% endif %}
		</div>
	</div>
</div>

<style>
	:root {
		--admin-primary: #0f62fe;
		--admin-success: #12805c;
		--admin-danger: #c0392b;
		--admin-info: #0043ce;
		--admin-bg: #f4f7fb;
		--admin-surface: #ffffff;
		--admin-border: #dbe4ee;
		--admin-text: #122033;
		--admin-muted: #607086;
		--admin-shadow: 0 20px 45px rgba(15, 48, 87, 0.08);
		--admin-shadow-sm: 0 2px 8px rgba(15, 48, 87, 0.06);
		--admin-radius: 12px;
		--admin-transition: all 0.3s ease;
	}

	.admin-dashboard {
		padding: 32px 0;
	}

	.dashboard-header {
		margin-bottom: 32px;
	}

	.dashboard-header h1 {
		font-size: 2rem;
		font-weight: 700;
		margin: 0 0 8px;
		color: var(--admin-text);
	}

	.dashboard-header .text-muted {
		color: var(--admin-muted);
		margin: 0;
	}

	/* Statistics Grid */
	.stats-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: 20px;
		margin-bottom: 32px;
	}

	.stat-card {
		background: var(--admin-surface);
		border-radius: var(--admin-radius);
		border: 1px solid var(--admin-border);
		padding: 24px;
		display: flex;
		align-items: center;
		gap: 16px;
		transition: var(--admin-transition);
		box-shadow: var(--admin-shadow-sm);
	}

	.stat-card:hover {
		transform: translateY(-2px);
		box-shadow: var(--admin-shadow);
		border-color: #bdd0e7;
	}

	.stat-card__icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 60px;
		height: 60px;
		border-radius: 12px;
		font-size: 28px;
	}

	.stat-card--primary .stat-card__icon {
		background: rgba(15, 98, 254, 0.1);
		color: var(--admin-primary);
	}

	.stat-card--success .stat-card__icon {
		background: rgba(18, 128, 92, 0.1);
		color: var(--admin-success);
	}

	.stat-card--info .stat-card__icon {
		background: rgba(0, 67, 206, 0.1);
		color: var(--admin-info);
	}

	.stat-card--danger .stat-card__icon {
		background: rgba(192, 57, 43, 0.1);
		color: var(--admin-danger);
	}

	.stat-card__content {
		flex: 1;
	}

	.stat-card__label {
		margin: 0 0 4px;
		font-size: 0.875rem;
		font-weight: 600;
		color: var(--admin-muted);
		text-transform: uppercase;
		letter-spacing: 0.5px;
	}

	.stat-card__value {
		margin: 0;
		font-size: 2rem;
		font-weight: 700;
		color: var(--admin-text);
	}

	/* Table Wrapper */
	.table-wrapper {
		background: var(--admin-surface);
		border-radius: var(--admin-radius);
		border: 1px solid var(--admin-border);
		overflow: hidden;
		box-shadow: var(--admin-shadow-sm);
	}

	.table-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 24px;
		border-bottom: 1px solid var(--admin-border);
	}

	.table-header h2 {
		margin: 0;
		font-size: 1.25rem;
		color: var(--admin-text);
	}

	.table-container {
		overflow-x: auto;
	}

	/* Modern Table */
	.modern-table {
		width: 100%;
		border-collapse: collapse;
	}

	.modern-table thead {
		background: var(--admin-bg);
		border-bottom: 2px solid var(--admin-border);
	}

	.modern-table th {
		padding: 16px 20px;
		text-align: left;
		font-size: 0.875rem;
		font-weight: 600;
		color: var(--admin-muted);
		text-transform: uppercase;
		letter-spacing: 0.5px;
	}

	.modern-table tbody tr {
		border-bottom: 1px solid var(--admin-border);
		transition: var(--admin-transition);
	}

	.modern-table tbody tr:hover {
		background: var(--admin-bg);
	}

	.modern-table td {
		padding: 16px 20px;
		color: var(--admin-text);
	}

	.td-id {
		font-weight: 600;
		color: var(--admin-primary);
	}

	/* Client Info */
	.client-info {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.client-avatar {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		border-radius: 50%;
		background: linear-gradient(135deg, var(--admin-primary), #0043ce);
		color: white;
		font-weight: 700;
		font-size: 0.875rem;
		flex-shrink: 0;
	}

	.client-name {
		margin: 0;
		font-weight: 600;
		color: var(--admin-text);
		font-size: 0.95rem;
	}

	.client-phone {
		margin: 4px 0 0;
		color: var(--admin-muted);
		font-size: 0.85rem;
	}

	/* Badges */
	.badge-company {
		display: inline-block;
		padding: 6px 12px;
		background: rgba(15, 98, 254, 0.1);
		color: var(--admin-primary);
		border-radius: 6px;
		font-size: 0.875rem;
		font-weight: 600;
	}

	.status-badge {
		display: inline-block;
		padding: 6px 12px;
		border-radius: 6px;
		font-size: 0.875rem;
		font-weight: 600;
		text-transform: capitalize;
	}

	.status-badge--submitted {
		background: rgba(0, 67, 206, 0.1);
		color: var(--admin-info);
	}

	.status-badge--accepted {
		background: rgba(18, 128, 92, 0.1);
		color: var(--admin-success);
	}

	.status-badge--rejected {
		background: rgba(192, 57, 43, 0.1);
		color: var(--admin-danger);
	}

	.status-badge--confirmed {
		background: rgba(15, 98, 254, 0.1);
		color: var(--admin-primary);
	}

	/* Price */
	.price {
		color: var(--admin-success);
		font-size: 1rem;
	}

	.date-time {
		color: var(--admin-muted);
		font-size: 0.875rem;
	}

	/* Buttons */
	.btn {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 10px 16px;
		border: none;
		border-radius: 6px;
		font-weight: 600;
		cursor: pointer;
		transition: var(--admin-transition);
		font-size: 0.875rem;
		text-decoration: none;
	}

	.btn-primary {
		background: var(--admin-primary);
		color: white;
	}

	.btn-primary:hover {
		background: #0a4bcc;
		transform: translateY(-1px);
		box-shadow: 0 4px 12px rgba(15, 98, 254, 0.3);
	}

	.btn-sm {
		padding: 8px 12px;
		font-size: 0.8rem;
	}

	.btn-icon {
		width: 36px;
		height: 36px;
		border: 1px solid var(--admin-border);
		background: transparent;
		border-radius: 6px;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--admin-muted);
		transition: var(--admin-transition);
		font-size: 0.875rem;
	}

	.btn-icon:hover {
		color: var(--admin-primary);
		border-color: var(--admin-primary);
		background: rgba(15, 98, 254, 0.05);
	}

	/* Empty State */
	.empty-state {
		text-align: center;
		padding: 60px 20px;
		color: var(--admin-muted);
	}

	.empty-state i {
		font-size: 3rem;
		margin-bottom: 16px;
		opacity: 0.5;
	}

	.empty-state p {
		margin: 0;
		font-size: 1.1rem;
	}

	/* Utility Classes */
	.text-muted {
		color: var(--admin-muted);
	}

	.text-center {
		text-align: center;
	}

	/* Responsive */
	@media (max-width: 768px) {
		.admin-dashboard {
			padding: 16px 0;
		}

		.dashboard-header h1 {
			font-size: 1.5rem;
		}

		.stats-grid {
			grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
			gap: 12px;
		}

		.stat-card {
			flex-direction: column;
			text-align: center;
			padding: 16px;
		}

		.stat-card__icon {
			width: 48px;
			height: 48px;
			font-size: 20px;
		}

		.stat-card__value {
			font-size: 1.75rem;
		}

		.table-header {
			flex-direction: column;
			align-items: flex-start;
			gap: 12px;
			padding: 16px;
		}

		.table-header h2 {
			font-size: 1.1rem;
		}

		.modern-table th,
		.modern-table td {
			padding: 12px 8px;
			font-size: 0.8rem;
		}

		.client-info {
			gap: 8px;
		}

		.client-avatar {
			width: 32px;
			height: 32px;
			font-size: 0.75rem;
		}

		.client-name {
			font-size: 0.85rem;
		}

		.client-phone {
			display: none;
		}
	}

	@media (max-width: 480px) {
		.stats-grid {
			grid-template-columns: 1fr 1fr;
		}

		.stat-card__value {
			font-size: 1.5rem;
		}

		.table-header {
			padding: 12px;
		}

		.table-container {
			font-size: 0.8rem;
		}

		.modern-table th,
		.modern-table td {
			padding: 10px 4px;
		}
	}
</style>
{% endblock %}
