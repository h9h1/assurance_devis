# Vite reads this automatically.
# The proxy target — where your Symfony app is running.
#
# Common values:
#   Standard Symfony local server (HTTP):  http://127.0.0.1:8000
#   Standard Symfony local server (HTTPS): https://localhost:8000
#   DDEV:                                  https://assur-quote-symfony.ddev.site
#
# Change this to match YOUR local setup, then restart `npm run dev`.

VITE_API_TARGET=https://localhost:8000
